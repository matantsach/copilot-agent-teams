  "description": "Multi-agent team coordination plugin for GitHub Copilot CLI",
  "type": "commonjs",
  "main": "dist/mcp-server/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "tsx src/mcp-server/index.ts",
